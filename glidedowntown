-- SETTINGS
------------------------------------------------
local GlideEnabled = false
local DASH_POWER = 3.0
local MODIFIER_KEY = Enum.KeyCode.Space

------------------------------------------------
-- CHARACTER HELPERS
------------------------------------------------
local function getChar()
	return Player.Character or Player.CharacterAdded:Wait()
end

local function getHRP()
	return getChar():WaitForChild("HumanoidRootPart")
end

------------------------------------------------
-- GLIDE LOGIC
------------------------------------------------
local function applyDash(directionVector)
	local hrp = getHRP()

	if not hrp or not GlideEnabled then
		return
	end

	-- tuned scaling
	local scaledPower = DASH_POWER * 3.35

	hrp.AssemblyLinearVelocity =
		hrp.AssemblyLinearVelocity + (directionVector * scaledPower)
end

local function getDirectionFromKeys()
	local camera = workspace.CurrentCamera

	if not camera then
		return nil
	end

	local look = Vector3.new(
		camera.CFrame.LookVector.X,
		0,
		camera.CFrame.LookVector.Z
	).Unit

	local right = Vector3.new(
		camera.CFrame.RightVector.X,
		0,
		camera.CFrame.RightVector.Z
	).Unit

	local finalDir = Vector3.zero

	if UIS:IsKeyDown(Enum.KeyCode.W) then
		finalDir += look
	end

	if UIS:IsKeyDown(Enum.KeyCode.S) then
		finalDir -= look
	end

	if UIS:IsKeyDown(Enum.KeyCode.A) then
		finalDir -= right
	end

	if UIS:IsKeyDown(Enum.KeyCode.D) then
		finalDir += right
	end

	if finalDir.Magnitude > 0 then
		return finalDir.Unit
	end

	return nil
end

------------------------------------------------
-- INPUTS
------------------------------------------------
UIS.InputBegan:Connect(function(input, gpe)
	if gpe or not GlideEnabled then
		return
	end

	local camera = workspace.CurrentCamera

	if not camera then
		return
	end

	local look = Vector3.new(
		camera.CFrame.LookVector.X,
		0,
		camera.CFrame.LookVector.Z
	).Unit

	local right = Vector3.new(
		camera.CFrame.RightVector.X,
		0,
		camera.CFrame.RightVector.Z
	).Unit

	if UIS:IsKeyDown(MODIFIER_KEY) then
		if input.KeyCode == Enum.KeyCode.W then
			applyDash(look)

		elseif input.KeyCode == Enum.KeyCode.S then
			applyDash(-look)

		elseif input.KeyCode == Enum.KeyCode.A then
			applyDash(-right)

		elseif input.KeyCode == Enum.KeyCode.D then
			applyDash(right)
		end
	end

	if input.KeyCode == MODIFIER_KEY then
		local dir = getDirectionFromKeys()

		if dir then
			applyDash(dir)
		end
	end
end)

