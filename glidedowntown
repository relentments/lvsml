------------------------------------------------
-- SLIDER LOGIC
------------------------------------------------
local draggingSlider = false

SliderKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = true
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = false
	end
end)

RunService.RenderStepped:Connect(function()
	if draggingSlider then
		local mouseX = UIS:GetMouseLocation().X

		local barX = SliderBack.AbsolutePosition.X
		local barSize = SliderBack.AbsoluteSize.X

		local percent =
			math.clamp((mouseX - barX) / barSize, 0, 1)

		SliderKnob.Position =
			UDim2.new(percent, -7, 0.5, -7)

		SliderFill.Size =
			UDim2.new(percent, 0, 1, 0)

		local power = 3 + (percent * 17)

		DASH_POWER =
			tonumber(string.format("%.1f", power))

		SliderLabel.Text =
			"Glide Power: " .. tostring(DASH_POWER)

		------------------------------------------------
		-- STATUS INDICATOR
		------------------------------------------------
		if DASH_POWER >= 3 and DASH_POWER < 5 then
			StatusLabel.Text = "LEGIT"
			StatusLabel.TextColor3 =
				Color3.fromRGB(0,255,120)

		elseif DASH_POWER >= 5 and DASH_POWER < 7 then
			StatusLabel.Text = "MODERATE"
			StatusLabel.TextColor3 =
				Color3.fromRGB(255,170,0)

		else
			StatusLabel.Text = "BLATANT"
			StatusLabel.TextColor3 =
				Color3.fromRGB(255,70,70)
		end
	end
end)

